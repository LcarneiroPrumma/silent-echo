{
  "name": "silent-echo",
  "version": "0.1.0",
  "description": "🔇 SILENT ECHO - Terror Acústico Reverso. Um jogo de horror inovador onde o silêncio é a chave para a sobrevivência.",
  "main": "src/index.js",
  "homepage": "https://github.com/LcarneiroPrumma/silent-echo",
  "repository": {
    "type": "git",
    "url": "https://github.com/LcarneiroPrumma/silent-echo.git"
  },
  "keywords": [
    "phaser",
    "phaser3",
    "game",
    "horror",
    "audio",
    "microphone",
    "echolocation",
    "web-audio-api"
  ],
  "author": "LcarneiroPrumma",
  "license": "MIT",
  "scripts": {
    "start": "webpack serve --mode development",
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "deploy": "npm run build && npm run deploy:gh-pages",
    "deploy:gh-pages": "gh-pages -d dist"
  },
  "dependencies": {
    "phaser": "^3.55.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "prettier": "^3.0.3",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}